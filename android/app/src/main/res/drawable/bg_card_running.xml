<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <item>
        <shape android:shape="rectangle">
            <solid android:color="#0e1421"/>
            <stroke android:width="1dp" android:color="#2d22c55e"/>
            <corners android:radius="10dp"/>
        </shape>
    </item>
    <!-- Top accent bar: green → cyan (matches CSS .stat-card.accent-green:hover) -->
    <item android:gravity="top" android:height="2dp">
        <shape android:shape="rectangle">
            <gradient android:type="linear" android:angle="0"
                android:startColor="#22c55e"
                android:endColor="#06b6d4"/>
            <corners android:topLeftRadius="10dp" android:topRightRadius="10dp"/>
        </shape>
    </item>
</layer-list>
