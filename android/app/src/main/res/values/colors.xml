<?xml version="1.0" encoding="utf-8"?>
<resources>

    <!-- VOID Theme: matches WebIF CSS variables exactly -->

    <!-- Core backgrounds: bg, s1, s2, s3, s4 -->
    <color name="void_bg">#090d14</color>
    <color name="void_surface">#0e1421</color>
    <color name="void_surface_var">#141c2e</color>
    <color name="void_surface_hover">#1a2340</color>
    <color name="void_surface_active">#202b47</color>

    <!-- Primary: Electric Blue (p, p2, ps, pg) -->
    <color name="void_primary">#3b82f6</color>
    <color name="void_primary_dim">#2563eb</color>
    <color name="void_primary_container">#1e2d47</color>
    <color name="void_primary_glow">#383b82f6</color>

    <!-- Secondary: Violet (vi, vis) -->
    <color name="void_secondary">#8b5cf6</color>
    <color name="void_secondary_container">#1a1535</color>

    <!-- Tertiary: Cyan (cy) -->
    <color name="void_tertiary">#06b6d4</color>

    <!-- Text: t0, t1, t2 -->
    <color name="void_on_surface">#e8f0fe</color>
    <color name="void_on_surface_var">#94a3b8</color>
    <color name="void_text_muted">#4b6584</color>
    <color name="void_on_primary">#ffffff</color>
    <color name="void_on_secondary">#ffffff</color>

    <!-- Borders: bd, bd2 -->
    <color name="void_outline">#1e2d47</color>
    <color name="void_outline_var">#253554</color>

    <!-- Status semantic colours -->
    <color name="color_running">#22c55e</color>
    <color name="color_stopped">#ef4444</color>
    <color name="color_warning">#f97316</color>
    <color name="color_warning2">#fb923c</color>
    <color name="color_violet">#8b5cf6</color>
    <color name="color_cyan">#06b6d4</color>

    <!-- Warning bar -->
    <color name="warn_bar_bg">#1af97316</color>

    <!-- Log / terminal: deeper black matching webif lw bg (#040810) -->
    <color name="log_bg">#040810</color>
    <color name="log_surface">#0a0f1a</color>
    <color name="log_separator">#1a2340</color>
    <color name="log_text">#94a3b8</color>
    <color name="log_text_dim">#4b6584</color>

    <!-- Log line colours matching webif JS colorLine() -->
    <color name="log_col_ok">#4ade80</color>
    <color name="log_col_miss">#f87171</color>
    <color name="log_col_webif">#60a5fa</color>
    <color name="log_col_ban">#fb923c</color>
    <color name="log_col_net">#c084fc</color>
    <color name="log_col_proto">#22d3ee</color>
    <color name="log_col_emu">#86efac</color>
    <color name="log_col_conf">#fde68a</color>
    <color name="log_col_err">#f87171</color>
    <color name="log_col_warn">#fb923c</color>

    <!-- Nav item colour state list is defined in res/color/nav_item_color.xml -->

</resources>
