<?xml version="1.0" encoding="utf-8"?>
<!--
    fragment_log.xml  —  VOID theme terminal viewer
    Chrome bar (traffic lights) · scrollable log · filter bar · status footer
-->
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/log_bg">

    <!-- ── Chrome title bar ────────────────────────────────────────── -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="44dp"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:background="@color/log_surface"
        android:paddingStart="14dp"
        android:paddingEnd="14dp">

        <!-- macOS-style traffic lights -->
        <View
            android:layout_width="11dp"
            android:layout_height="11dp"
            android:background="@drawable/status_dot_stopped"
            android:layout_marginEnd="6dp"/>
        <View
            android:layout_width="11dp"
            android:layout_height="11dp"
            android:background="@drawable/status_dot"
            android:layout_marginEnd="6dp"/>
        <View
            android:layout_width="11dp"
            android:layout_height="11dp"
            android:background="@drawable/status_dot_running"
            android:layout_marginEnd="16dp"/>

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="tcmg — server output"
            android:fontFamily="monospace"
            android:textSize="11sp"
            android:gravity="center"
            android:textColor="@color/log_text_dim"/>

        <!-- LIVE indicator -->
        <TextView
            android:id="@+id/tvLiveBadge"
            android:layout_width="wrap_content"
            android:layout_height="22dp"
            android:text=" LIVE "
            android:fontFamily="monospace"
            android:textSize="9sp"
            android:textStyle="bold"
            android:letterSpacing="0.12"
            android:textColor="@color/color_running"
            android:background="@drawable/bg_live_badge"
            android:gravity="center"/>
    </LinearLayout>

    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="@color/log_separator"/>

    <!-- ── Filter bar ──────────────────────────────────────────────── -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="40dp"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:background="@color/log_surface"
        android:paddingStart="10dp"
        android:paddingEnd="10dp">

        <!-- Search icon -->
        <ImageView
            android:layout_width="16dp"
            android:layout_height="16dp"
            android:src="@drawable/ic_search"
            android:contentDescription="@null"
            android:tint="@color/log_text_dim"
            android:layout_marginEnd="6dp"/>

        <EditText
            android:id="@+id/etLogFilter"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:hint="Filter log..."
            android:fontFamily="monospace"
            android:textSize="12sp"
            android:textColor="@color/log_text"
            android:textColorHint="@color/log_text_dim"
            android:background="@android:color/transparent"
            android:inputType="text"
            android:maxLines="1"
            android:imeOptions="actionDone"/>

        <!-- Clear filter -->
        <ImageView
            android:id="@+id/ivClearFilter"
            android:layout_width="28dp"
            android:layout_height="28dp"
            android:src="@drawable/ic_close"
            android:contentDescription="Clear filter"
            android:tint="@color/log_text_dim"
            android:padding="6dp"
            android:visibility="gone"/>

        <View
            android:layout_width="1dp"
            android:layout_height="16dp"
            android:background="@color/log_separator"
            android:layout_marginStart="6dp"
            android:layout_marginEnd="8dp"/>

        <!-- Auto-scroll toggle -->
        <ImageView
            android:id="@+id/ivAutoScroll"
            android:layout_width="28dp"
            android:layout_height="28dp"
            android:src="@drawable/ic_scroll_down"
            android:contentDescription="Auto-scroll"
            android:tint="@color/color_running"
            android:padding="4dp"/>

        <!-- Pause toggle -->
        <ImageView
            android:id="@+id/ivPause"
            android:layout_width="28dp"
            android:layout_height="28dp"
            android:src="@drawable/ic_pause"
            android:contentDescription="Pause"
            android:tint="@color/log_text_dim"
            android:padding="4dp"
            android:layout_marginStart="4dp"/>
    </LinearLayout>

    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="@color/log_separator"/>

    <!-- ── Log content ─────────────────────────────────────────────── -->
    <ScrollView
        android:id="@+id/svLog"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:fillViewport="true"
        android:overScrollMode="never"
        android:clipToPadding="false"
        android:paddingBottom="4dp">

        <TextView
            android:id="@+id/tvLog"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:fontFamily="monospace"
            android:textSize="12sp"
            android:textColor="@color/log_text"
            android:textIsSelectable="true"
            android:lineSpacingMultiplier="1.65"
            android:paddingStart="14dp"
            android:paddingEnd="14dp"
            android:paddingTop="10dp"
            android:paddingBottom="10dp"/>
    </ScrollView>

    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="@color/log_separator"/>

    <!-- ── Status footer ───────────────────────────────────────────── -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="32dp"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:background="@color/log_surface"
        android:paddingStart="14dp"
        android:paddingEnd="14dp">

        <View
            android:id="@+id/vLogDot"
            android:layout_width="6dp"
            android:layout_height="6dp"
            android:background="@drawable/status_dot"
            android:layout_marginEnd="8dp"/>

        <TextView
            android:id="@+id/tvLogStatus"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="idle"
            android:fontFamily="monospace"
            android:textSize="10sp"
            android:textColor="@color/log_text_dim"/>

        <TextView
            android:id="@+id/tvLogLineCount"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="0 lines"
            android:fontFamily="monospace"
            android:textSize="10sp"
            android:textColor="@color/log_text_dim"/>
    </LinearLayout>

</LinearLayout>
