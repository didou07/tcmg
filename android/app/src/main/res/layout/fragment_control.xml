<?xml version="1.0" encoding="utf-8"?>
<!--
    fragment_control.xml — VOID theme
    Cleaned: removed duplicate version badge from header (version already in Toolbar),
    removed duplicate Uptime from status card (kept in stat grid only),
    WebIF buttons hidden (GONE) when server is stopped,
    CW Miss and Banned IPs icon badges now use correct colour drawables.
-->
<androidx.core.widget.NestedScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="?attr/android:colorBackground"
    android:overScrollMode="never"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingStart="14dp"
        android:paddingEnd="14dp"
        android:paddingTop="12dp"
        android:paddingBottom="80dp">

        <!-- STATUS CARD -->
        <LinearLayout
            android:id="@+id/statusCard"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp"
            android:layout_marginBottom="12dp"
            android:background="@drawable/bg_card_stopped">

            <!-- Row 1: pulse dot + status text -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="38dp"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginBottom="14dp">

                <ImageView
                    android:id="@+id/statusDot"
                    android:layout_width="10dp"
                    android:layout_height="10dp"
                    android:src="@drawable/status_dot_stopped"
                    android:layout_marginEnd="10dp"
                    android:contentDescription="@null"/>

                <TextView
                    android:id="@+id/tvStatusText"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="@string/status_stopped"
                    android:textSize="17sp"
                    android:textStyle="bold"
                    android:fontFamily="sans-serif-medium"
                    android:textColor="?attr/colorOnSurface"/>

            </LinearLayout>

            <!-- Row 2: START | STOP buttons -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:orientation="horizontal">

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnStart"
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_weight="1"
                    android:layout_marginEnd="6dp"
                    android:text="@string/btn_start"
                    android:textSize="13sp"
                    android:insetTop="0dp"
                    android:insetBottom="0dp"
                    app:cornerRadius="8dp"
                    style="@style/Widget.Material3.Button"/>

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnStop"
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_weight="1"
                    android:layout_marginStart="6dp"
                    android:text="@string/btn_stop"
                    android:textSize="13sp"
                    android:insetTop="0dp"
                    android:insetBottom="0dp"
                    android:enabled="false"
                    app:cornerRadius="8dp"
                    style="@style/Widget.Material3.Button.TonalButton"/>
            </LinearLayout>
        </LinearLayout>

        <!-- STAT CARDS GRID (2x3): matches WebIF .cg / .sc -->
        <GridLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:columnCount="2"
            android:rowCount="3"
            android:useDefaultMargins="false"
            android:layout_marginBottom="14dp">

            <!-- Uptime card (blue) — single source of truth for uptime -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/cardUptime"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_columnWeight="1"
                android:layout_margin="4dp"
                app:strokeColor="#473b82f6"
                app:strokeWidth="1dp"
                app:cardCornerRadius="10dp"
                app:cardElevation="0dp"
                app:cardBackgroundColor="#0a3b82f6">
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:padding="12dp"
                    android:gravity="center_vertical">
                    <LinearLayout
                        android:layout_width="38dp"
                        android:layout_height="38dp"
                        android:background="@drawable/bg_version_badge"
                        android:gravity="center"
                        android:layout_marginEnd="10dp">
                        <ImageView android:layout_width="20dp" android:layout_height="20dp"
                            android:src="@drawable/ic_stat_clock"
                            android:tint="@color/void_primary"
                            android:contentDescription="@null"/>
                    </LinearLayout>
                    <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
                        android:layout_weight="1" android:orientation="vertical">
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="UPTIME" android:textSize="9sp" android:textStyle="bold"
                            android:fontFamily="sans-serif-medium" android:letterSpacing="0.10"
                            android:textAllCaps="true" android:textColor="@color/void_on_surface_var"/>
                        <TextView android:id="@+id/tvStatUptime"
                            android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="—" android:textSize="17sp" android:textStyle="bold"
                            android:fontFamily="monospace" android:textColor="@color/void_on_surface"/>
                    </LinearLayout>
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- Connections card -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/cardConns"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_columnWeight="1"
                android:layout_margin="4dp"
                app:strokeColor="#471e2d47"
                app:strokeWidth="1dp"
                app:cardCornerRadius="10dp"
                app:cardElevation="0dp"
                app:cardBackgroundColor="@color/void_surface">
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:padding="12dp"
                    android:gravity="center_vertical">
                    <LinearLayout
                        android:id="@+id/iconBgConns"
                        android:layout_width="38dp"
                        android:layout_height="38dp"
                        android:background="@drawable/bg_badge_blue"
                        android:gravity="center"
                        android:layout_marginEnd="10dp">
                        <ImageView android:id="@+id/iconConns"
                            android:layout_width="20dp" android:layout_height="20dp"
                            android:src="@drawable/ic_stat_users"
                            android:tint="@color/void_primary"
                            android:contentDescription="@null"/>
                    </LinearLayout>
                    <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
                        android:layout_weight="1" android:orientation="vertical">
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="CONNECTIONS" android:textSize="9sp" android:textStyle="bold"
                            android:fontFamily="sans-serif-medium" android:letterSpacing="0.10"
                            android:textAllCaps="true" android:textColor="@color/void_on_surface_var"/>
                        <TextView android:id="@+id/tvStatConns"
                            android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="0" android:textSize="22sp" android:textStyle="bold"
                            android:fontFamily="monospace" android:textColor="@color/void_on_surface"/>
                    </LinearLayout>
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- CW Found (green) -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/cardCwFound"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_columnWeight="1"
                android:layout_margin="4dp"
                app:strokeColor="#4722c55e"
                app:strokeWidth="1dp"
                app:cardCornerRadius="10dp"
                app:cardElevation="0dp"
                app:cardBackgroundColor="#0a22c55e">
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:padding="12dp"
                    android:gravity="center_vertical">
                    <LinearLayout
                        android:layout_width="38dp"
                        android:layout_height="38dp"
                        android:background="@drawable/bg_badge_green"
                        android:gravity="center"
                        android:layout_marginEnd="10dp">
                        <ImageView android:layout_width="20dp" android:layout_height="20dp"
                            android:src="@drawable/ic_stat_check"
                            android:tint="@color/color_running"
                            android:contentDescription="@null"/>
                    </LinearLayout>
                    <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
                        android:layout_weight="1" android:orientation="vertical">
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="CW FOUND" android:textSize="9sp" android:textStyle="bold"
                            android:fontFamily="sans-serif-medium" android:letterSpacing="0.10"
                            android:textAllCaps="true" android:textColor="@color/void_on_surface_var"/>
                        <TextView android:id="@+id/tvStatCwFound"
                            android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="0" android:textSize="22sp" android:textStyle="bold"
                            android:fontFamily="monospace" android:textColor="@color/void_on_surface"/>
                    </LinearLayout>
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- CW Miss: icon badge turns red when misses > 0 (fixed from always-blue) -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/cardCwMiss"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_columnWeight="1"
                android:layout_margin="4dp"
                app:strokeColor="#471e2d47"
                app:strokeWidth="1dp"
                app:cardCornerRadius="10dp"
                app:cardElevation="0dp"
                app:cardBackgroundColor="@color/void_surface">
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:padding="12dp"
                    android:gravity="center_vertical">
                    <LinearLayout
                        android:id="@+id/iconBgCwMiss"
                        android:layout_width="38dp"
                        android:layout_height="38dp"
                        android:background="@drawable/bg_badge_blue"
                        android:gravity="center"
                        android:layout_marginEnd="10dp">
                        <ImageView
                            android:id="@+id/iconCwMiss"
                            android:layout_width="20dp" android:layout_height="20dp"
                            android:src="@drawable/ic_stat_x"
                            android:tint="@color/void_on_surface_var"
                            android:contentDescription="@null"/>
                    </LinearLayout>
                    <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
                        android:layout_weight="1" android:orientation="vertical">
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="CW MISS" android:textSize="9sp" android:textStyle="bold"
                            android:fontFamily="sans-serif-medium" android:letterSpacing="0.10"
                            android:textAllCaps="true" android:textColor="@color/void_on_surface_var"/>
                        <TextView android:id="@+id/tvStatCwMiss"
                            android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="0" android:textSize="22sp" android:textStyle="bold"
                            android:fontFamily="monospace" android:textColor="@color/void_on_surface"/>
                    </LinearLayout>
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- Hit Rate (cyan) -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/cardHitRate"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_columnWeight="1"
                android:layout_margin="4dp"
                app:strokeColor="#4706b6d4"
                app:strokeWidth="1dp"
                app:cardCornerRadius="10dp"
                app:cardElevation="0dp"
                app:cardBackgroundColor="#0a06b6d4">
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:padding="12dp"
                    android:gravity="center_vertical">
                    <LinearLayout
                        android:layout_width="38dp"
                        android:layout_height="38dp"
                        android:background="@drawable/bg_badge_blue"
                        android:gravity="center"
                        android:layout_marginEnd="10dp">
                        <ImageView android:layout_width="20dp" android:layout_height="20dp"
                            android:src="@drawable/ic_stat_percent"
                            android:tint="@color/void_tertiary"
                            android:contentDescription="@null"/>
                    </LinearLayout>
                    <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
                        android:layout_weight="1" android:orientation="vertical">
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="HIT RATE" android:textSize="9sp" android:textStyle="bold"
                            android:fontFamily="sans-serif-medium" android:letterSpacing="0.10"
                            android:textAllCaps="true" android:textColor="@color/void_on_surface_var"/>
                        <TextView android:id="@+id/tvStatHitRate"
                            android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="0.0%" android:textSize="22sp" android:textStyle="bold"
                            android:fontFamily="monospace" android:textColor="@color/void_on_surface"/>
                        <ProgressBar
                            android:id="@+id/pbHitRate"
                            style="@android:style/Widget.ProgressBar.Horizontal"
                            android:layout_width="match_parent"
                            android:layout_height="4dp"
                            android:layout_marginTop="4dp"
                            android:max="100"
                            android:progress="0"
                            android:progressTint="@color/void_tertiary"
                            android:progressBackgroundTint="@color/void_surface_active"/>
                    </LinearLayout>
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- Banned IPs: icon badge turns orange when bans > 0 (fixed from always-blue) -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/cardBans"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_columnWeight="1"
                android:layout_margin="4dp"
                app:strokeColor="#471e2d47"
                app:strokeWidth="1dp"
                app:cardCornerRadius="10dp"
                app:cardElevation="0dp"
                app:cardBackgroundColor="@color/void_surface">
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:padding="12dp"
                    android:gravity="center_vertical">
                    <LinearLayout
                        android:id="@+id/iconBgBans"
                        android:layout_width="38dp"
                        android:layout_height="38dp"
                        android:background="@drawable/bg_badge_blue"
                        android:gravity="center"
                        android:layout_marginEnd="10dp">
                        <ImageView
                            android:id="@+id/iconBans"
                            android:layout_width="20dp" android:layout_height="20dp"
                            android:src="@drawable/ic_stat_shield"
                            android:tint="@color/void_on_surface_var"
                            android:contentDescription="@null"/>
                    </LinearLayout>
                    <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
                        android:layout_weight="1" android:orientation="vertical">
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="BANNED IPS" android:textSize="9sp" android:textStyle="bold"
                            android:fontFamily="sans-serif-medium" android:letterSpacing="0.10"
                            android:textAllCaps="true" android:textColor="@color/void_on_surface_var"/>
                        <TextView android:id="@+id/tvStatBans"
                            android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="0" android:textSize="22sp" android:textStyle="bold"
                            android:fontFamily="monospace" android:textColor="@color/void_on_surface"/>
                    </LinearLayout>
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

        </GridLayout>

        <!-- NETWORK CARD: WebIF buttons visible only when server is running -->
        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="12dp"
            app:strokeColor="?attr/colorOutline"
            app:strokeWidth="1dp"
            app:cardCornerRadius="10dp"
            app:cardElevation="0dp"
            app:cardBackgroundColor="?attr/colorSurface">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:paddingStart="14dp"
                android:paddingEnd="14dp"
                android:paddingTop="12dp"
                android:paddingBottom="12dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/label_network"
                    android:textSize="10sp"
                    android:fontFamily="sans-serif-medium"
                    android:letterSpacing="0.10"
                    android:textAllCaps="true"
                    android:textColor="?attr/colorOnSurfaceVariant"
                    android:layout_marginBottom="10dp"/>

                <!-- Wi-Fi row -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="46dp"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:background="@drawable/bg_surface_rounded"
                    android:paddingStart="12dp"
                    android:paddingEnd="8dp"
                    android:layout_marginBottom="6dp">

                    <TextView
                        android:layout_width="64dp"
                        android:layout_height="wrap_content"
                        android:text="@string/label_wifi"
                        android:textSize="11sp"
                        android:textStyle="bold"
                        android:fontFamily="sans-serif-medium"
                        android:textColor="?attr/colorOnSurfaceVariant"/>

                    <TextView
                        android:id="@+id/tvWifiIp"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="@string/hint_not_available"
                        android:fontFamily="monospace"
                        android:textSize="13sp"
                        android:textColor="?attr/colorOnSurface"/>

                    <!-- Hidden by default; shown only when TCMG is running -->
                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnWebifWifi"
                        android:layout_width="80dp"
                        android:layout_height="32dp"
                        android:text="@string/btn_webif"
                        android:textSize="10sp"
                        android:insetTop="0dp"
                        android:insetBottom="0dp"
                        android:enabled="false"
                        android:visibility="gone"
                        app:cornerRadius="6dp"
                        style="@style/Widget.Material3.Button.OutlinedButton"/>
                </LinearLayout>

                <!-- Hotspot row -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="46dp"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:background="@drawable/bg_surface_rounded"
                    android:paddingStart="12dp"
                    android:paddingEnd="8dp">

                    <TextView
                        android:layout_width="64dp"
                        android:layout_height="wrap_content"
                        android:text="@string/label_hotspot"
                        android:textSize="11sp"
                        android:textStyle="bold"
                        android:fontFamily="sans-serif-medium"
                        android:textColor="?attr/colorOnSurfaceVariant"/>

                    <TextView
                        android:id="@+id/tvHotspotIp"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="@string/hint_not_available"
                        android:fontFamily="monospace"
                        android:textSize="13sp"
                        android:textColor="?attr/colorOnSurface"/>

                    <!-- Hidden by default; shown only when TCMG is running -->
                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnWebifHotspot"
                        android:layout_width="80dp"
                        android:layout_height="32dp"
                        android:text="@string/btn_webif"
                        android:textSize="10sp"
                        android:insetTop="0dp"
                        android:insetBottom="0dp"
                        android:enabled="false"
                        android:visibility="gone"
                        app:cornerRadius="6dp"
                        style="@style/Widget.Material3.Button.OutlinedButton"/>
                </LinearLayout>
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- SETTINGS CARD -->
        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:strokeColor="?attr/colorOutline"
            app:strokeWidth="1dp"
            app:cardCornerRadius="10dp"
            app:cardElevation="0dp"
            app:cardBackgroundColor="?attr/colorSurface">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:paddingStart="14dp"
                android:paddingEnd="14dp"
                android:paddingTop="12dp"
                android:paddingBottom="12dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/label_settings"
                    android:textSize="10sp"
                    android:fontFamily="sans-serif-medium"
                    android:letterSpacing="0.10"
                    android:textAllCaps="true"
                    android:textColor="?attr/colorOnSurfaceVariant"
                    android:layout_marginBottom="10dp"/>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="52dp"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:background="@drawable/bg_surface_rounded"
                    android:paddingStart="12dp"
                    android:paddingEnd="10dp">

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/label_autostart"
                            android:textSize="13sp"
                            android:fontFamily="sans-serif-medium"
                            android:textColor="?attr/colorOnSurface"/>

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Start on device boot"
                            android:textSize="10sp"
                            android:textColor="?attr/colorOnSurfaceVariant"/>
                    </LinearLayout>

                    <com.google.android.material.materialswitch.MaterialSwitch
                        android:id="@+id/switchAutostart"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"/>
                </LinearLayout>
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

    </LinearLayout>
</androidx.core.widget.NestedScrollView>
