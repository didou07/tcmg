<?xml version="1.0" encoding="utf-8"?>
<!--
    fragment_control.xml — VOID theme
    Stat cards + status + network + settings, matching WebIF dashboard layout.
-->
<androidx.core.widget.NestedScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="?attr/android:colorBackground"
    android:overScrollMode="never"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingStart="14dp"
        android:paddingEnd="14dp"
        android:paddingTop="12dp"
        android:paddingBottom="80dp">

        <!-- ══ HEADER ════════════════════════════════════════════════ -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="14dp">

            <!-- Logo icon box (matches WebIF .li) -->
            <LinearLayout
                android:layout_width="32dp"
                android:layout_height="32dp"
                android:background="@drawable/bg_version_badge"
                android:gravity="center"
                android:layout_marginEnd="10dp">
                <ImageView
                    android:layout_width="18dp"
                    android:layout_height="18dp"
                    android:src="@drawable/ic_nav_control"
                    android:contentDescription="@null"
                    android:tint="@color/void_primary"/>
            </LinearLayout>

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="@string/app_name"
                android:textSize="17sp"
                android:textStyle="bold"
                android:fontFamily="sans-serif-medium"
                android:letterSpacing="0.01"
                android:textColor="?attr/colorOnSurface"/>

            <!-- Version badge -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="v4.4"
                android:fontFamily="monospace"
                android:textSize="10sp"
                android:textColor="?attr/colorPrimary"
                android:background="@drawable/bg_version_badge"
                android:paddingStart="8dp"
                android:paddingEnd="8dp"
                android:paddingTop="3dp"
                android:paddingBottom="3dp"/>
        </LinearLayout>

        <!-- ══ STATUS CARD ═══════════════════════════════════════════ -->
        <LinearLayout
            android:id="@+id/statusCard"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp"
            android:layout_marginBottom="12dp"
            android:background="@drawable/bg_card_stopped">

            <!-- Row 1: pulse dot + status text + uptime -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="38dp"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginBottom="14dp">

                <ImageView
                    android:id="@+id/statusDot"
                    android:layout_width="10dp"
                    android:layout_height="10dp"
                    android:src="@drawable/status_dot_stopped"
                    android:layout_marginEnd="10dp"
                    android:contentDescription="@null"/>

                <TextView
                    android:id="@+id/tvStatusText"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="@string/status_stopped"
                    android:textSize="17sp"
                    android:textStyle="bold"
                    android:fontFamily="sans-serif-medium"
                    android:textColor="?attr/colorOnSurface"/>

                <!-- Uptime (GONE when stopped) -->
                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:gravity="end">

                    <TextView
                        android:id="@+id/tvUptimeLabel"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/status_uptime"
                        android:textSize="8sp"
                        android:fontFamily="monospace"
                        android:letterSpacing="0.18"
                        android:textColor="?attr/colorOnSurfaceVariant"
                        android:visibility="gone"/>

                    <TextView
                        android:id="@+id/tvUptime"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="00:00:00"
                        android:textSize="15sp"
                        android:fontFamily="monospace"
                        android:textColor="?attr/colorPrimary"
                        android:textStyle="bold"
                        android:visibility="gone"/>
                </LinearLayout>
            </LinearLayout>

            <!-- Row 2: START | STOP buttons -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:orientation="horizontal">

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnStart"
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_weight="1"
                    android:layout_marginEnd="6dp"
                    android:text="@string/btn_start"
                    android:textSize="13sp"
                    android:insetTop="0dp"
                    android:insetBottom="0dp"
                    app:cornerRadius="8dp"
                    style="@style/Widget.Material3.Button"/>

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnStop"
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_weight="1"
                    android:layout_marginStart="6dp"
                    android:text="@string/btn_stop"
                    android:textSize="13sp"
                    android:insetTop="0dp"
                    android:insetBottom="0dp"
                    android:enabled="false"
                    app:cornerRadius="8dp"
                    style="@style/Widget.Material3.Button.TonalButton"/>
            </LinearLayout>
        </LinearLayout>

        <!-- ══ STAT CARDS GRID (2×3) ══════════════════════════════════
             Matches WebIF stat card layout .cg / .sc
        ══════════════════════════════════════════════════════════════ -->
        <GridLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:columnCount="2"
            android:rowCount="3"
            android:useDefaultMargins="false"
            android:layout_marginBottom="14dp">

            <!-- Uptime card (blue) -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/cardUptime"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_columnWeight="1"
                android:layout_margin="4dp"
                app:strokeColor="#473b82f6"
                app:strokeWidth="1dp"
                app:cardCornerRadius="10dp"
                app:cardElevation="0dp"
                app:cardBackgroundColor="#0a3b82f6">
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:padding="12dp"
                    android:gravity="center_vertical">
                    <LinearLayout
                        android:layout_width="38dp"
                        android:layout_height="38dp"
                        android:background="@drawable/bg_version_badge"
                        android:gravity="center"
                        android:layout_marginEnd="10dp">
                        <ImageView android:layout_width="20dp" android:layout_height="20dp"
                            android:src="@drawable/ic_stat_clock"
                            android:tint="@color/void_primary"
                            android:contentDescription="@null"/>
                    </LinearLayout>
                    <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
                        android:layout_weight="1" android:orientation="vertical">
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="UPTIME" android:textSize="9sp" android:textStyle="bold"
                            android:fontFamily="sans-serif-medium" android:letterSpacing="0.10"
                            android:textAllCaps="true" android:textColor="@color/void_on_surface_var"/>
                        <TextView android:id="@+id/tvStatUptime"
                            android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="—" android:textSize="17sp" android:textStyle="bold"
                            android:fontFamily="monospace" android:textColor="@color/void_on_surface"/>
                    </LinearLayout>
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- Connections card (green when active) -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/cardConns"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_columnWeight="1"
                android:layout_margin="4dp"
                app:strokeColor="#471e2d47"
                app:strokeWidth="1dp"
                app:cardCornerRadius="10dp"
                app:cardElevation="0dp"
                app:cardBackgroundColor="@color/void_surface">
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:padding="12dp"
                    android:gravity="center_vertical">
                    <LinearLayout
                        android:layout_width="38dp"
                        android:layout_height="38dp"
                        android:background="@drawable/bg_badge_blue"
                        android:gravity="center"
                        android:layout_marginEnd="10dp">
                        <ImageView android:layout_width="20dp" android:layout_height="20dp"
                            android:src="@drawable/ic_stat_users"
                            android:tint="@color/void_primary"
                            android:contentDescription="@null"/>
                    </LinearLayout>
                    <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
                        android:layout_weight="1" android:orientation="vertical">
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="CONNECTIONS" android:textSize="9sp" android:textStyle="bold"
                            android:fontFamily="sans-serif-medium" android:letterSpacing="0.10"
                            android:textAllCaps="true" android:textColor="@color/void_on_surface_var"/>
                        <TextView android:id="@+id/tvStatConns"
                            android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="0" android:textSize="22sp" android:textStyle="bold"
                            android:fontFamily="monospace" android:textColor="@color/void_on_surface"/>
                    </LinearLayout>
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- CW Found (green) -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/cardCwFound"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_columnWeight="1"
                android:layout_margin="4dp"
                app:strokeColor="#4722c55e"
                app:strokeWidth="1dp"
                app:cardCornerRadius="10dp"
                app:cardElevation="0dp"
                app:cardBackgroundColor="#0a22c55e">
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:padding="12dp"
                    android:gravity="center_vertical">
                    <LinearLayout
                        android:layout_width="38dp"
                        android:layout_height="38dp"
                        android:background="@drawable/bg_badge_green"
                        android:gravity="center"
                        android:layout_marginEnd="10dp">
                        <ImageView android:layout_width="20dp" android:layout_height="20dp"
                            android:src="@drawable/ic_stat_check"
                            android:tint="@color/color_running"
                            android:contentDescription="@null"/>
                    </LinearLayout>
                    <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
                        android:layout_weight="1" android:orientation="vertical">
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="CW FOUND" android:textSize="9sp" android:textStyle="bold"
                            android:fontFamily="sans-serif-medium" android:letterSpacing="0.10"
                            android:textAllCaps="true" android:textColor="@color/void_on_surface_var"/>
                        <TextView android:id="@+id/tvStatCwFound"
                            android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="0" android:textSize="22sp" android:textStyle="bold"
                            android:fontFamily="monospace" android:textColor="@color/void_on_surface"/>
                    </LinearLayout>
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- CW Miss (red when > 0) -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/cardCwMiss"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_columnWeight="1"
                android:layout_margin="4dp"
                app:strokeColor="#471e2d47"
                app:strokeWidth="1dp"
                app:cardCornerRadius="10dp"
                app:cardElevation="0dp"
                app:cardBackgroundColor="@color/void_surface">
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:padding="12dp"
                    android:gravity="center_vertical">
                    <LinearLayout
                        android:layout_width="38dp"
                        android:layout_height="38dp"
                        android:background="@drawable/bg_badge_blue"
                        android:gravity="center"
                        android:layout_marginEnd="10dp">
                        <ImageView android:layout_width="20dp" android:layout_height="20dp"
                            android:src="@drawable/ic_stat_x"
                            android:tint="@color/void_on_surface_var"
                            android:contentDescription="@null"/>
                    </LinearLayout>
                    <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
                        android:layout_weight="1" android:orientation="vertical">
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="CW MISS" android:textSize="9sp" android:textStyle="bold"
                            android:fontFamily="sans-serif-medium" android:letterSpacing="0.10"
                            android:textAllCaps="true" android:textColor="@color/void_on_surface_var"/>
                        <TextView android:id="@+id/tvStatCwMiss"
                            android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="0" android:textSize="22sp" android:textStyle="bold"
                            android:fontFamily="monospace" android:textColor="@color/void_on_surface"/>
                    </LinearLayout>
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- Hit Rate (cyan) -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/cardHitRate"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_columnWeight="1"
                android:layout_margin="4dp"
                app:strokeColor="#4706b6d4"
                app:strokeWidth="1dp"
                app:cardCornerRadius="10dp"
                app:cardElevation="0dp"
                app:cardBackgroundColor="#0a06b6d4">
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:padding="12dp"
                    android:gravity="center_vertical">
                    <LinearLayout
                        android:layout_width="38dp"
                        android:layout_height="38dp"
                        android:background="@drawable/bg_badge_blue"
                        android:gravity="center"
                        android:layout_marginEnd="10dp">
                        <ImageView android:layout_width="20dp" android:layout_height="20dp"
                            android:src="@drawable/ic_stat_percent"
                            android:tint="@color/void_tertiary"
                            android:contentDescription="@null"/>
                    </LinearLayout>
                    <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
                        android:layout_weight="1" android:orientation="vertical">
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="HIT RATE" android:textSize="9sp" android:textStyle="bold"
                            android:fontFamily="sans-serif-medium" android:letterSpacing="0.10"
                            android:textAllCaps="true" android:textColor="@color/void_on_surface_var"/>
                        <TextView android:id="@+id/tvStatHitRate"
                            android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="0.0%" android:textSize="22sp" android:textStyle="bold"
                            android:fontFamily="monospace" android:textColor="@color/void_on_surface"/>
                        <!-- Hit bar -->
                        <ProgressBar
                            android:id="@+id/pbHitRate"
                            style="@android:style/Widget.ProgressBar.Horizontal"
                            android:layout_width="match_parent"
                            android:layout_height="4dp"
                            android:layout_marginTop="4dp"
                            android:max="100"
                            android:progress="0"
                            android:progressTint="@color/void_tertiary"
                            android:progressBackgroundTint="@color/void_surface_active"/>
                    </LinearLayout>
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- Banned IPs (orange when > 0) -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/cardBans"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_columnWeight="1"
                android:layout_margin="4dp"
                app:strokeColor="#471e2d47"
                app:strokeWidth="1dp"
                app:cardCornerRadius="10dp"
                app:cardElevation="0dp"
                app:cardBackgroundColor="@color/void_surface">
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:padding="12dp"
                    android:gravity="center_vertical">
                    <LinearLayout
                        android:layout_width="38dp"
                        android:layout_height="38dp"
                        android:background="@drawable/bg_badge_blue"
                        android:gravity="center"
                        android:layout_marginEnd="10dp">
                        <ImageView android:layout_width="20dp" android:layout_height="20dp"
                            android:src="@drawable/ic_stat_shield"
                            android:tint="@color/void_on_surface_var"
                            android:contentDescription="@null"/>
                    </LinearLayout>
                    <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
                        android:layout_weight="1" android:orientation="vertical">
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="BANNED IPS" android:textSize="9sp" android:textStyle="bold"
                            android:fontFamily="sans-serif-medium" android:letterSpacing="0.10"
                            android:textAllCaps="true" android:textColor="@color/void_on_surface_var"/>
                        <TextView android:id="@+id/tvStatBans"
                            android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="0" android:textSize="22sp" android:textStyle="bold"
                            android:fontFamily="monospace" android:textColor="@color/void_on_surface"/>
                    </LinearLayout>
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

        </GridLayout>

        <!-- ══ NETWORK CARD ══════════════════════════════════════════ -->
        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="12dp"
            app:strokeColor="?attr/colorOutline"
            app:strokeWidth="1dp"
            app:cardCornerRadius="10dp"
            app:cardElevation="0dp"
            app:cardBackgroundColor="?attr/colorSurface">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:paddingStart="14dp"
                android:paddingEnd="14dp"
                android:paddingTop="12dp"
                android:paddingBottom="12dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/label_network"
                    android:textSize="10sp"
                    android:fontFamily="sans-serif-medium"
                    android:letterSpacing="0.10"
                    android:textAllCaps="true"
                    android:textColor="?attr/colorOnSurfaceVariant"
                    android:layout_marginBottom="10dp"/>

                <!-- Wi-Fi row -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="46dp"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:background="@drawable/bg_surface_rounded"
                    android:paddingStart="12dp"
                    android:paddingEnd="8dp"
                    android:layout_marginBottom="6dp">

                    <TextView
                        android:layout_width="64dp"
                        android:layout_height="wrap_content"
                        android:text="@string/label_wifi"
                        android:textSize="11sp"
                        android:textStyle="bold"
                        android:fontFamily="sans-serif-medium"
                        android:textColor="?attr/colorOnSurfaceVariant"/>

                    <TextView
                        android:id="@+id/tvWifiIp"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="@string/hint_not_available"
                        android:fontFamily="monospace"
                        android:textSize="13sp"
                        android:textColor="?attr/colorOnSurface"/>

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnWebifWifi"
                        android:layout_width="80dp"
                        android:layout_height="32dp"
                        android:text="@string/btn_webif"
                        android:textSize="10sp"
                        android:insetTop="0dp"
                        android:insetBottom="0dp"
                        android:enabled="false"
                        app:cornerRadius="6dp"
                        style="@style/Widget.Material3.Button.OutlinedButton"/>
                </LinearLayout>

                <!-- Hotspot row -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="46dp"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:background="@drawable/bg_surface_rounded"
                    android:paddingStart="12dp"
                    android:paddingEnd="8dp">

                    <TextView
                        android:layout_width="64dp"
                        android:layout_height="wrap_content"
                        android:text="@string/label_hotspot"
                        android:textSize="11sp"
                        android:textStyle="bold"
                        android:fontFamily="sans-serif-medium"
                        android:textColor="?attr/colorOnSurfaceVariant"/>

                    <TextView
                        android:id="@+id/tvHotspotIp"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="@string/hint_not_available"
                        android:fontFamily="monospace"
                        android:textSize="13sp"
                        android:textColor="?attr/colorOnSurface"/>

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnWebifHotspot"
                        android:layout_width="80dp"
                        android:layout_height="32dp"
                        android:text="@string/btn_webif"
                        android:textSize="10sp"
                        android:insetTop="0dp"
                        android:insetBottom="0dp"
                        android:enabled="false"
                        app:cornerRadius="6dp"
                        style="@style/Widget.Material3.Button.OutlinedButton"/>
                </LinearLayout>
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- ══ SETTINGS CARD ════════════════════════════════════════ -->
        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:strokeColor="?attr/colorOutline"
            app:strokeWidth="1dp"
            app:cardCornerRadius="10dp"
            app:cardElevation="0dp"
            app:cardBackgroundColor="?attr/colorSurface">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:paddingStart="14dp"
                android:paddingEnd="14dp"
                android:paddingTop="12dp"
                android:paddingBottom="12dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/label_settings"
                    android:textSize="10sp"
                    android:fontFamily="sans-serif-medium"
                    android:letterSpacing="0.10"
                    android:textAllCaps="true"
                    android:textColor="?attr/colorOnSurfaceVariant"
                    android:layout_marginBottom="10dp"/>

                <!-- Autostart row -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="52dp"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:background="@drawable/bg_surface_rounded"
                    android:paddingStart="12dp"
                    android:paddingEnd="10dp">

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/label_autostart"
                            android:textSize="13sp"
                            android:fontFamily="sans-serif-medium"
                            android:textColor="?attr/colorOnSurface"/>

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Start on device boot"
                            android:textSize="10sp"
                            android:textColor="?attr/colorOnSurfaceVariant"/>
                    </LinearLayout>

                    <com.google.android.material.materialswitch.MaterialSwitch
                        android:id="@+id/switchAutostart"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"/>
                </LinearLayout>
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

    </LinearLayout>
</androidx.core.widget.NestedScrollView>
