<?xml version="1.0" encoding="utf-8"?>
<!--
    fragment_editor.xml  —  VOID theme config editor
    File tabs · code editor · Ctrl+S hint · bottom action bar
-->
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="?attr/android:colorBackground">

    <!-- ── File tab bar ────────────────────────────────────────────── -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="44dp"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:background="?attr/colorSurface"
        android:paddingStart="14dp"
        android:paddingEnd="14dp">

        <!-- File icon -->
        <ImageView
            android:layout_width="16dp"
            android:layout_height="16dp"
            android:src="@drawable/ic_file"
            android:contentDescription="@null"
            android:tint="?attr/colorPrimary"
            android:layout_marginEnd="8dp"/>

        <com.google.android.material.tabs.TabLayout
            android:id="@+id/tabLayoutEditor"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            app:tabMode="fixed"
            app:tabGravity="fill"
            style="@style/Widget.TCMG.TabLayout"/>

        <!-- Unsaved indicator dot -->
        <View
            android:id="@+id/vUnsavedDot"
            android:layout_width="7dp"
            android:layout_height="7dp"
            android:background="@drawable/bg_unsaved_dot"
            android:layout_marginStart="10dp"
            android:visibility="gone"/>
    </LinearLayout>

    <!-- Divider -->
    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="?attr/colorOutline"/>

    <!-- ── Warning bar (server running) ────────────────────────────── -->
    <LinearLayout
        android:id="@+id/warnBar"
        android:layout_width="match_parent"
        android:layout_height="34dp"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:background="@color/warn_bar_bg"
        android:paddingStart="14dp"
        android:paddingEnd="14dp">

        <ImageView
            android:layout_width="13dp"
            android:layout_height="13dp"
            android:src="@drawable/ic_warn"
            android:contentDescription="@null"
            android:tint="@color/color_warning"
            android:layout_marginEnd="8dp"/>

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Server running — restart required to apply changes"
            android:fontFamily="monospace"
            android:textSize="10.5sp"
            android:textColor="@color/color_warning"/>
    </LinearLayout>

    <!-- ── Code editor ─────────────────────────────────────────────── -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:paddingStart="10dp"
        android:paddingEnd="10dp"
        android:paddingTop="6dp"
        android:paddingBottom="4dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:background="@drawable/bg_code_editor"
            android:orientation="vertical">

            <!-- Line numbers + editor row -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:orientation="horizontal">

                <!-- Line number gutter -->
                <ScrollView
                    android:id="@+id/svLineNums"
                    android:layout_width="36dp"
                    android:layout_height="match_parent"
                    android:fillViewport="true"
                    android:overScrollMode="never"
                    android:scrollbars="none">

                    <TextView
                        android:id="@+id/tvLineNums"
                        android:layout_width="36dp"
                        android:layout_height="wrap_content"
                        android:fontFamily="monospace"
                        android:textSize="12sp"
                        android:lineSpacingMultiplier="1.65"
                        android:textColor="@color/log_text_dim"
                        android:gravity="end"
                        android:paddingStart="4dp"
                        android:paddingEnd="8dp"
                        android:paddingTop="12dp"
                        android:paddingBottom="12dp"
                        android:alpha="0.5"
                        android:text="1"/>
                </ScrollView>

                <!-- Gutter divider -->
                <View
                    android:layout_width="1dp"
                    android:layout_height="match_parent"
                    android:background="@color/log_separator"/>

                <!-- The actual editor -->
                <ScrollView
                    android:id="@+id/svEditor"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:fillViewport="true"
                    android:overScrollMode="never">

                    <EditText
                        android:id="@+id/etEditor"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:minHeight="300dp"
                        android:fontFamily="monospace"
                        android:textSize="13sp"
                        android:lineSpacingMultiplier="1.65"
                        android:textColor="@color/log_text"
                        android:textColorHint="@color/log_text_dim"
                        android:background="@android:color/transparent"
                        android:paddingStart="10dp"
                        android:paddingEnd="14dp"
                        android:paddingTop="12dp"
                        android:paddingBottom="12dp"
                        android:gravity="top|start"
                        android:inputType="textMultiLine|textNoSuggestions"
                        android:scrollHorizontally="false"
                        android:hint="Loading…"/>
                </ScrollView>
            </LinearLayout>
        </LinearLayout>
    </LinearLayout>

    <!-- Cursor position bar -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="26dp"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:background="?attr/colorSurface"
        android:paddingStart="14dp"
        android:paddingEnd="14dp">

        <TextView
            android:id="@+id/tvEdStatus"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="● Saved"
            android:fontFamily="monospace"
            android:textSize="10sp"
            android:textColor="@color/color_running"/>

        <TextView
            android:id="@+id/tvEdCursor"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Ln 1, Col 1"
            android:fontFamily="monospace"
            android:textSize="10sp"
            android:textColor="@color/log_text_dim"/>
    </LinearLayout>

    <!-- Divider -->
    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="?attr/colorOutline"/>

    <!-- ── Action bar ───────────────────────────────────────────────── -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:paddingStart="10dp"
        android:paddingEnd="10dp"
        android:paddingTop="6dp"
        android:paddingBottom="8dp">

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnReload"
            android:layout_width="0dp"
            android:layout_height="38dp"
            android:layout_weight="1"
            android:layout_marginEnd="5dp"
            android:text="@string/editor_reload"
            android:textSize="12sp"
            android:insetTop="0dp"
            android:insetBottom="0dp"
            app:icon="@drawable/ic_reload"
            app:iconSize="14dp"
            app:iconGravity="textStart"
            app:cornerRadius="8dp"
            style="@style/Widget.Material3.Button.TonalButton"/>

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnSave"
            android:layout_width="0dp"
            android:layout_height="38dp"
            android:layout_weight="1"
            android:layout_marginStart="5dp"
            android:text="@string/editor_save"
            android:textSize="12sp"
            android:insetTop="0dp"
            android:insetBottom="0dp"
            app:icon="@drawable/ic_save"
            app:iconSize="14dp"
            app:iconGravity="textStart"
            app:cornerRadius="8dp"
            style="@style/Widget.Material3.Button"/>
    </LinearLayout>

</LinearLayout>
